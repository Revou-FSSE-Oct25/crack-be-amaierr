generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model authorization {
  menuIndex Int    @map("menu_index")
  roleId    String @map("role_id") @db.Uuid
  menuId    String @map("menu_id") @db.Uuid

  menu menu @relation(fields: [menuId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_menu")
  role role @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_role")

  @@id([menuId, roleId])
  @@map("authorizations")
}

enum LevelTypes {
  Beginner
  Intermediate
  Advanced
}

model category {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String     @db.VarChar
  
  courses course[]

  @@map("categories")
}

model course {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String     @db.VarChar
  description String     @db.VarChar
  levelType   LevelTypes @map("level_type")
  rating      Decimal    @default(0) @db.Decimal(2, 1)
  students    Int        @default(0)
  instructor  String     @db.Uuid
  categoryId  String     @db.Uuid @map("category_id")

  user         user           @relation(fields: [instructor], references: [id], onDelete: NoAction, onUpdate: NoAction)
  category     category       @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  curriculumns curriculumn[]
  enrollments  enrollment[]

  @@map("courses")
}

model curriculumn {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId String @map("course_id") @db.Uuid
  name     String @db.VarChar(50)

  course         course            @relation(fields: [courseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subCurriculums sub_curriculumn[]

  @@map("curriculumns")
}

model enrollment {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String  @map("user_id") @db.Uuid
  courseId           String  @map("course_id") @db.Uuid
  progressPercentage Int     @map("progress_percentage")
  review             String? @db.VarChar

  course course @relation(fields: [courseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user   user   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("enrollments")
}

model menu {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String          @unique @db.VarChar(50)
  path           String          @db.VarChar(50)
  label          String          @db.VarChar(50)
  icon           String          @db.VarChar(50)
  authorizations authorization[]

  @@map("menus")
}

model progress {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  subCurriculumId String   @map("sub_curriculumn_id") @db.Uuid
  isDone          Boolean? @default(false) @map("is_done")

  subCurriculum sub_curriculumn @relation(fields: [subCurriculumId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user          user            @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("progresses")
}

model role {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code String @unique
  name String @db.VarChar(50)

  authorizations authorization[]
  users          user[]

  @@map("roles")
}

model sub_curriculumn {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  curriculumnId String @map("curriculumn_id") @db.Uuid
  name          String @db.VarChar(50)
  materialLink  String @map("material_link") @db.VarChar

  progresses  progress[]
  curriculumn curriculumn @relation(fields: [curriculumnId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("sub_curriculumns")
}

model user {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String @db.VarChar
  email    String @unique @db.VarChar
  password String @db.VarChar
  roleId   String @map("role_id") @db.Uuid

  courses     course[]
  enrollments enrollment[]
  progresses  progress[]
  role        role         @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("users")
}
